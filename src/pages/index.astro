---
/**
 * Photography Journey — default route `/`.
 * Island: PhotographyJourney.vue (client:visible) — Phase A5
 * Composable: useStatistics() + useGallery()
 */
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Photography Journey — syamim."
  description="Syamim Hakimi's photography journey — statistics, featured photos, and film simulation recipes."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <h1 class="text-3xl font-bold sm:text-4xl">Photography Journey</h1>
      <p class="mt-2 text-[var(--color-text-muted)]">
        A visual diary — film simulations, statistics, and favourite frames.
      </p>
    </header>

    <section aria-label="Photography Journey content">
      <!--
        PhotographyJourney island mounted here in Phase A5.
        Uses: useStatistics() for charts, useGallery() for featured photos.
      -->
      <p class="text-[var(--color-text-muted)]">Content loading…</p>
    </section>
  </div>
</PageLayout>
