---
/**
 * Home — default route `/`.
 * Editorial hero: photography canvas (left dominant) + identity stack (right).
 * Photo grid island: LandingPhotos.vue (via HomePhotoCanvas, client:visible)
 */
import PageLayout from "../layouts/PageLayout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomePhotoCanvas from "../components/home/HomePhotoCanvas.astro";
import HomeFreelancePanel from "../components/home/HomeFreelancePanel.astro";
import HomeServicesStrip from "../components/home/HomeServicesStrip.astro";
import HomeSectionCard from "../components/home/HomeSectionCard.astro";
import HomeTechNote from "../components/home/HomeTechNote.astro";

const homeCards = {
  portfolio: {
    href: "/portfolio",
    title: "Portfolio",
    description:
      "Full-stack engineering across web, mobile, and cloud. Systems designed for scale, maintainability, and great UX.",
    ctaText: "See my work",
    ariaLabel: "Portfolio - see my work",
    variant: "card-elevated" as const,
    chips: ["TypeScript", "Vue", "Firebase", "Python"],
    icon: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  },
  services: {
    href: "/services",
    title: "Services",
    description:
      "Available for freelance and consulting - web development, system design, code reviews, and technical mentoring.",
    ctaText: "Work with me",
    ariaLabel: "Services - work with me",
    variant: "card-outlined" as const,
    chips: ["Web Dev", "Consulting", "Mentoring"],
    icon: `<path d="M4 7h16"/><path d="M7 4v6"/><path d="M17 4v6"/><path d="M5 11h14l-1 8H6l-1-8Z"/>`,
  },
  about: {
    href: "/about",
    title: "About me",
    description:
      "Off the clock - the hobbies, gear, and games that keep me going.",
    ctaText: "More about me",
    ariaLabel: "About me",
    variant: "card-filled" as const,
    icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  },
};
---

<PageLayout
  title="syamim. — Software Engineer & Photographer"
  description="Syamim Hakimi — software engineer based in Malaysia. I build clean, thoughtful software and occasionally point a camera at beautiful things."
>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">

    <!-- Editorial hero: photo canvas (dominant left) + identity stack (right) -->
    <div class="mb-3.5 grid grid-cols-1 gap-3.5 lg:grid-cols-[5fr_4fr]">
      <HomePhotoCanvas />

      <!-- Identity stack: hero grows to fill, freelance panel anchors at bottom -->
      <div class="flex flex-col gap-3.5 lg:h-full">
        <HomeHero />
        <HomeFreelancePanel />
      </div>
    </div>

    <!-- Services availability strip -->
    <HomeServicesStrip />

    <!-- Section bento grid: 1-col mobile → 2-col tablet → 3-col desktop -->
    <div class="mb-3.5 grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
      <HomeSectionCard {...homeCards.portfolio} />
      <HomeSectionCard {...homeCards.services} />
      <HomeSectionCard {...homeCards.about}>
        <div class="flex flex-col gap-2.5">
          <div class="flex items-center gap-2.5">
            <div class="icon-disc !h-8 !w-8 flex-shrink-0" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                <circle cx="12" cy="13" r="4"></circle>
              </svg>
            </div>
            <div>
              <p class="text-[13px] font-medium text-[var(--color-on-surface)]">Photography</p>
              <p class="text-[11px] text-[var(--color-on-surface-variant)]">Fujifilm · Film simulations</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="icon-disc !h-8 !w-8 flex-shrink-0" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                <line x1="2" y1="10" x2="22" y2="10"></line>
              </svg>
            </div>
            <div>
              <p class="text-[13px] font-medium text-[var(--color-on-surface)]">Boardgames</p>
              <p class="text-[11px] text-[var(--color-on-surface-variant)]">Strategy · Favourites</p>
            </div>
          </div>
        </div>
      </HomeSectionCard>
    </div>

    <HomeTechNote />
  </div>
</PageLayout>
