---
/**
 * Services — route `/services`.
 * Island: ServicesSection.vue (client:visible)
 * Composable: useServices()
 */
import PageLayout from "../layouts/PageLayout.astro";
import ServicesSection from "../components/islands/ServicesSection.vue";
---

<PageLayout
  title="Services — syamim."
  description="Web development services offered by Syamim Hakimi — custom web apps, API design, database design, and more."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12 max-w-4xl">
      <div class="mb-4 flex items-center gap-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-full bg-[color:var(--color-cta-soft,rgba(37,99,235,0.1))] text-[var(--color-cta)]"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            class="h-5 w-5"
          >
            <path d="M4 7h16" />
            <path d="M7 4v6" />
            <path d="M17 4v6" />
            <path d="M5 11h14l-1 8H6l-1-8Z" />
          </svg>
        </span>
        <span
          class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--color-on-surface-variant)]"
        >
          Software Engineering Services
        </span>
      </div>
      <h1>Services</h1>
      <p class="mt-3 max-w-2xl text-[var(--color-on-surface-variant)]">
        Build support across product delivery, platform foundations, and
        hardening work — scoped to help ship cleaner, more deliberate software.
      </p>
    </header>

    <ServicesSection client:visible />
  </div>
</PageLayout>
