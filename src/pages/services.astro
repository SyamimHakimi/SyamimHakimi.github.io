---
/**
 * Services — route `/services`.
 * Island: ServicesSection.vue (client:visible)
 * Composable: useServices()
 */
import PageLayout from "../layouts/PageLayout.astro";
import ServicesSection from "../components/islands/ServicesSection.vue";
---

<PageLayout
  title="Services — syamim."
  description="Web development services offered by Syamim Hakimi — custom web apps, API design, database design, and more."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-3">
        <span class="icon-disc" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 7h16"/>
            <path d="M7 4v6"/>
            <path d="M17 4v6"/>
            <path d="M5 11h14l-1 8H6l-1-8Z"/>
          </svg>
        </span>
        <p class="text-[11px] font-bold uppercase tracking-[0.11em] text-[var(--color-on-surface-variant)]">
          Services
        </p>
      </div>
      <h1>Services</h1>
      <p class="mt-3 max-w-[52ch] text-base text-[var(--color-on-surface-variant)]">
        Build support across product delivery, platform foundations, and
        hardening work — scoped to help ship cleaner, more deliberate software.
      </p>
    </header>

    <ServicesSection client:visible />
  </div>
</PageLayout>
