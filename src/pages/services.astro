---
/**
 * Services — route `/services`.
 * Island: ServicesSection.vue (client:visible) — Phase A5
 * Composable: useServices()
 */
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Services — syamim."
  description="Web development services offered by Syamim Hakimi — custom web apps, API design, database design, and more."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <h1 class="text-3xl font-bold sm:text-4xl">Services</h1>
      <p class="mt-2 text-[var(--color-text-muted)]">
        Web development offerings — from API design to full-stack applications.
      </p>
    </header>

    <section aria-label="Services">
      <!--
        ServicesSection island mounted here in Phase A5.
        Uses: useServices() — services collection ordered by sorting field.
      -->
      <p class="text-[var(--color-text-muted)]">Services loading…</p>
    </section>
  </div>
</PageLayout>
