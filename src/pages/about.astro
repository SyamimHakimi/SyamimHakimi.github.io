---
/**
 * About — route `/about`.
 * Island: AboutMe.vue (client:visible)
 * Composable: useAboutMe()
 * The island owns the profile card, gear, boardgames, and social sections.
 * The page-level header (eyebrow + h1 + subtitle) lives here, matching the
 * other pages.
 */
import PageLayout from "../layouts/PageLayout.astro";
import AboutMe from "../components/islands/AboutMe.vue";
---

<PageLayout
  title="About — syamim."
  description="About Syamim Hakimi — profile, photography gear, favourite boardgames, and social links."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-3">
        <span class="icon-disc" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </span>
        <p class="text-[11px] font-bold uppercase tracking-[0.11em] text-[var(--color-on-surface-variant)]">
          About
        </p>
      </div>
      <h1>The person behind the work.</h1>
      <p class="mt-3 max-w-[52ch] text-base text-[var(--color-on-surface-variant)]">
        A profile-first read on who I am, what I spend time on, and how
        software, photography, and boardgames fit together.
      </p>
    </header>

    <AboutMe client:visible />
  </div>
</PageLayout>
