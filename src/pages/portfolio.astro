---
/**
 * Portfolio — route `/portfolio`.
 * Island: PortfolioSection.vue (client:visible)
 * Composable: usePortfolio()
 */
import PageLayout from "../layouts/PageLayout.astro";
import PortfolioSection from "../components/islands/PortfolioSection.vue";
---

<PageLayout
  title="Portfolio — syamim."
  description="Syamim Hakimi's portfolio — professional experience, platforms, frameworks, and personal projects."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <div class="mb-2 flex items-center gap-3">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full" style="background:rgba(37,99,235,.10)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-cta)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </div>
        <h1>Portfolio</h1>
      </div>
      <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-on-surface-variant)]">
        Tools, platforms, and experiences that shaped how I build.
      </p>
    </header>

    <PortfolioSection client:visible />
  </div>
</PageLayout>
