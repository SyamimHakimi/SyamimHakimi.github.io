---
/**
 * Portfolio — route `/portfolio`.
 * Island: PortfolioSection.vue (client:visible)
 * Composable: usePortfolio()
 */
import PageLayout from "../layouts/PageLayout.astro";
import PortfolioSection from "../components/islands/PortfolioSection.vue";
---

<PageLayout
  title="Portfolio — syamim."
  description="Syamim Hakimi's portfolio — professional experience, platforms, frameworks, and personal projects."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-3">
        <span class="icon-disc" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </span>
        <p class="text-[11px] font-bold uppercase tracking-[0.11em] text-[var(--color-on-surface-variant)]">
          Portfolio
        </p>
      </div>
      <h1>Portfolio</h1>
      <p class="mt-3 max-w-[52ch] text-base text-[var(--color-on-surface-variant)]">
        Tools, platforms, and experiences that shaped how I build.
      </p>
    </header>

    <PortfolioSection client:visible />
  </div>
</PageLayout>
