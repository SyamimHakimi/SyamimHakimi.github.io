---
/**
 * Photography Journey — route `/photography-journey`.
 * Island: PhotographyJourney.vue (client:visible)
 * Composable: useStatistics()
 */
import PageLayout from "../layouts/PageLayout.astro";
import PhotographyJourneyIsland from "../components/islands/PhotographyJourney.vue";
import RouteHeader from "../components/ui/RouteHeader.astro";
import PhotographyPipeline from "../components/photography/PhotographyPipeline.astro";
---

<PageLayout
  title="Photography Journey — syamim."
  description="Syamim Hakimi's photography journey — statistics, featured photos, and film simulation recipes."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <RouteHeader
      eyebrow="Photography Journey"
      title="Photography Journey"
      description="A visual diary — film simulations, statistics, and favourite frames."
    >
      <Fragment slot="icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
          <polyline points="17 6 23 6 23 12"/>
        </svg>
      </Fragment>
    </RouteHeader>

    <PhotographyJourneyIsland client:visible />

    <div class="mt-4">
      <PhotographyPipeline />
    </div>
  </div>
</PageLayout>
