---
/**
 * Full gallery — route `/photography`.
 * Island: GalleryGrid.vue (client:visible) — includes GalleryLightbox internally
 * Composable: useGallery()
 */
import PageLayout from "../layouts/PageLayout.astro";
import GalleryGrid from "../components/islands/GalleryGrid.vue";
---

<PageLayout
  title="Photography — syamim."
  description="Syamim Hakimi's photography gallery — favourite shots sorted by date."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-3">
        <span class="icon-disc" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </span>
        <p class="text-[11px] font-bold uppercase tracking-[0.11em] text-[var(--color-on-surface-variant)]">
          Gallery
        </p>
      </div>
      <h1>Gallery</h1>
      <p class="mt-3 max-w-[52ch] text-base text-[var(--color-on-surface-variant)]">
        Favourite frames — film simulations on a Fujifilm X-E4.
      </p>
      <!-- Gear strip (static — gear rarely changes) -->
      <div class="mt-3 flex flex-wrap items-center gap-x-2.5 gap-y-1.5 text-[13px] text-[var(--color-on-surface-variant)]">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0 opacity-60">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
        <span class="opacity-60">Shot on</span>
        <span class="font-medium text-[var(--color-on-surface)]">Fujifilm X-E4</span>
        <span aria-hidden="true" class="opacity-40">·</span>
        <span>Sigma 10-18mm F2.8</span>
        <span aria-hidden="true" class="opacity-40">·</span>
        <span>Sigma 18-50mm F2.8</span>
        <span aria-hidden="true" class="opacity-40">·</span>
        <span>Viltrox 56mm F1.7</span>
      </div>
    </header>

    <GalleryGrid client:visible />
  </div>
</PageLayout>
