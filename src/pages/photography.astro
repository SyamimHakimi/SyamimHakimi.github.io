---
/**
 * Full gallery — route `/photography`.
 * Island: GalleryGrid.vue (client:visible) — includes GalleryLightbox internally
 * Composable: useGallery()
 */
import PageLayout from "../layouts/PageLayout.astro";
import GalleryGrid from "../components/islands/GalleryGrid.vue";
---

<PageLayout
  title="Photography — syamim."
  description="Syamim Hakimi's photography gallery — favourite shots sorted by date."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <div class="mb-2 flex items-center gap-3">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full" style="background:rgba(37,99,235,.10)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-cta)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </div>
        <h1>Gallery</h1>
      </div>
      <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-on-surface-variant)]">
        Favourite frames — film simulations on a Fujifilm X-E4.
      </p>
    </header>

    <GalleryGrid client:visible />
  </div>
</PageLayout>
