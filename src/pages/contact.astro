---
/**
 * Contact — route `/contact`.
 * Island: ContactForm.vue (client:load — EmailJS requires browser fetch API)
 */
import PageLayout from "../layouts/PageLayout.astro";
import ContactForm from "../components/islands/ContactForm.vue";
---

<PageLayout
  title="Contact — syamim."
  description="Get in touch with Syamim Hakimi — web development enquiries and collaborations."
>
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <h1 class="text-3xl font-bold sm:text-4xl">Contact</h1>
      <p class="mt-2 text-[var(--color-text-muted)]">
        Have a project in mind? Let&apos;s talk.
      </p>
    </header>

    <ContactForm client:load />
  </div>
</PageLayout>
