---
/**
 * Contact — route `/contact`.
 * Island: ContactForm.vue (client:visible — static contact links, no JS on mount)
 * The island owns the info card and contact layout.
 * The page-level header (eyebrow + h1 + subtitle) lives here, matching the
 * other pages.
 */
import PageLayout from "../layouts/PageLayout.astro";
import ContactForm from "../components/islands/ContactForm.vue";
import RouteHeader from "../components/ui/RouteHeader.astro";
---

<PageLayout
  title="Contact — syamim."
  description="Get in touch with Syamim Hakimi — web development enquiries and collaborations."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <RouteHeader
      eyebrow="Contact"
      title="Start with a clear message."
      description="Direct channels — no forms, no middleware. Pick the one that suits your project."
    >
      <Fragment slot="icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </Fragment>
    </RouteHeader>

    <ContactForm client:visible />
  </div>
</PageLayout>
