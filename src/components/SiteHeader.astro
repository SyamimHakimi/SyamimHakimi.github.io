---
/**
 * SiteHeader — desktop navigation rail + mobile top app bar + slide-in drawer.
 *
 * Desktop (≥lg): fixed 80px rail on the left — logo mark, 6 nav destinations (icon +
 * label), and ThemeToggle pinned to the bottom.
 *
 * Mobile (<lg): fixed 56px top app bar (hamburger, site name, ThemeToggle) and a
 * full-height slide-in drawer with all 6 destinations and a scrim overlay.
 *
 * ThemeToggle renders once per breakpoint (two instances total). Both write to the same
 * localStorage key and data-theme attribute. A MutationObserver in ThemeToggle keeps
 * icon state in sync when the attribute changes from the other instance.
 */
import ThemeToggle from "./islands/ThemeToggle.vue";

const navLinks = [
  { href: "/",            label: "Home",      icon: "home"      },
  { href: "/photography", label: "Gallery",   icon: "gallery"   },
  { href: "/portfolio",   label: "Portfolio", icon: "portfolio" },
  { href: "/services",    label: "Services",  icon: "services"  },
  { href: "/about",       label: "About",     icon: "about"     },
  { href: "/contact",     label: "Contact",   icon: "contact"   },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}

const currentPageLabel = navLinks.find((l) => isActive(l.href))?.label ?? "";

/**
 * Inline SVG icon paths — must match the icons used in each page's <header>.
 * Lucide-style, stroke, viewBox 0 0 24 24.
 */
const iconPaths: Record<string, string> = {
  // index.astro  — TrendingUp
  home:      `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  // photography.astro — Camera
  gallery:   `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>`,
  // portfolio.astro — Briefcase
  portfolio: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  // services.astro — shopping-bag tool
  services:  `<path d="M4 7h16"/><path d="M7 4v6"/><path d="M17 4v6"/><path d="M5 11h14l-1 8H6l-1-8Z"/>`,
  // about.astro — User
  about:     `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  // contact.astro — MessageSquare
  contact:   `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  menu:      `<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>`,
  close:     `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`,
};

function icon(name: string, size = 20): string {
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${iconPaths[name]}</svg>`;
}
---

<!-- Skip to main content (keyboard users) -->
<a href="#main-content" class="skip-link">Skip to content</a>

<!-- ════════════════════════════════════════════════════════════════
     Desktop: Fixed navigation rail (≥lg)
     ════════════════════════════════════════════════════════════════ -->
<nav
  class="hidden lg:flex fixed left-0 top-0 z-40 h-full w-20 flex-col items-center border-r border-[var(--color-outline)] bg-[var(--color-surface)] py-5"
  aria-label="Main navigation"
>
  <!-- Logo mark -->
  <a
    href="/"
    aria-label="syamim. — home"
    class="mb-6 flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--color-surface-variant)] text-xs font-bold tracking-wide text-[var(--color-on-surface)] transition-colors hover:bg-[var(--color-outline)]"
  >
    SH
  </a>

  <!-- Navigation items -->
  <ul class="flex w-full flex-col gap-1 px-2" role="list">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
          class:list={[
            "flex min-h-[48px] w-full flex-col items-center justify-center gap-1 rounded-xl px-1 py-2 transition-colors",
            isActive(link.href)
              ? "bg-[rgba(37,99,235,0.10)] dark:bg-[rgba(96,165,250,0.12)] text-[var(--color-cta)]"
              : "text-[var(--color-on-surface-variant)] hover:bg-[var(--color-surface-variant)] hover:text-[var(--color-on-surface)]",
          ]}
        >
          <Fragment set:html={icon(link.icon)} />
          <span class="text-[10px] font-medium leading-none">{link.label}</span>
        </a>
      </li>
    ))}
  </ul>

  <!-- ThemeToggle pinned to rail bottom -->
  <div class="mt-auto">
    <ThemeToggle client:load />
  </div>
</nav>


<!-- ════════════════════════════════════════════════════════════════
     Mobile: Fixed top app bar (<lg)
     ════════════════════════════════════════════════════════════════ -->
<header
  class="lg:hidden fixed left-0 right-0 top-0 z-40 flex h-14 items-center justify-between border-b border-[var(--color-outline)] bg-[var(--color-surface)] px-4"
>
  <!-- Site name + current page breadcrumb -->
  <a
    href="/"
    aria-label="syamim. — home"
    class="flex items-baseline gap-1.5 font-serif text-lg font-normal text-[var(--color-on-surface)] transition-colors hover:text-[var(--color-cta)]"
  >
    syamim.
    {currentPageLabel && currentPageLabel !== "Home" && (
      <span class="font-sans text-[12px] font-normal text-[var(--color-on-surface-variant)]">
        / {currentPageLabel}
      </span>
    )}
  </a>

  <!-- Right: ThemeToggle + hamburger -->
  <div class="flex items-center gap-1">
    <ThemeToggle client:load />
    <button
      id="nav-drawer-open"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
      class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-surface-variant)] text-[var(--color-on-surface-variant)] transition-colors hover:text-[var(--color-on-surface)]"
    >
      <Fragment set:html={icon("menu", 18)} />
    </button>
  </div>
</header>


<!-- ════════════════════════════════════════════════════════════════
     Mobile: Scrim overlay
     ════════════════════════════════════════════════════════════════ -->
<div
  id="nav-scrim"
  class="lg:hidden fixed inset-0 z-50 bg-[var(--color-scrim)]"
  aria-hidden="true"
  style="display: none;"
></div>


<!-- ════════════════════════════════════════════════════════════════
     Mobile: Navigation drawer
     ════════════════════════════════════════════════════════════════ -->
<nav
  id="nav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="lg:hidden fixed left-0 top-0 z-[60] flex h-full w-64 flex-col border-r border-[var(--color-outline)] bg-[var(--color-surface)]"
  style="transform: translateX(-100%);"
>
  <!-- Drawer header -->
  <div class="flex items-center justify-between border-b border-[var(--color-outline)] px-5 py-5">
    <span class="font-serif text-xl font-normal text-[var(--color-cta)]">
      Syamim Hakimi
    </span>
    <button
      id="nav-drawer-close"
      type="button"
      aria-label="Close navigation menu"
      class="flex h-8 w-8 items-center justify-center rounded-md text-[var(--color-on-surface-variant)] transition-colors hover:text-[var(--color-on-surface)]"
    >
      <Fragment set:html={icon("close")} />
    </button>
  </div>

  <!-- Navigation items -->
  <ul class="flex flex-col gap-0.5 py-2 pr-3" role="list">
    {navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
          class:list={[
            "flex items-center gap-3.5 rounded-r-3xl py-2.5 pl-5 text-sm font-medium transition-colors",
            isActive(link.href)
              ? "bg-[rgba(37,99,235,0.10)] dark:bg-[rgba(96,165,250,0.12)] text-[var(--color-cta)]"
              : "text-[var(--color-on-surface-variant)] hover:bg-[var(--color-surface-variant)] hover:text-[var(--color-on-surface)]",
          ]}
        >
          <Fragment set:html={icon(link.icon)} />
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>


<script>
  const openBtn = document.getElementById("nav-drawer-open");
  const closeBtn = document.getElementById("nav-drawer-close");
  const drawer = document.getElementById("nav-drawer") as HTMLElement | null;
  const scrim = document.getElementById("nav-scrim") as HTMLElement | null;

  function openDrawer() {
    if (!drawer || !scrim) return;
    drawer.style.transform = "translateX(0)";
    scrim.style.display = "block";
    openBtn?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    // Move focus to close button for keyboard accessibility
    (closeBtn as HTMLElement | null)?.focus();
  }

  function closeDrawer() {
    if (!drawer || !scrim) return;
    drawer.style.transform = "translateX(-100%)";
    scrim.style.display = "none";
    openBtn?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    // Return focus to the trigger button
    (openBtn as HTMLElement | null)?.focus();
  }

  openBtn?.addEventListener("click", openDrawer);
  closeBtn?.addEventListener("click", closeDrawer);
  scrim?.addEventListener("click", closeDrawer);

  // Close on Escape key
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && scrim?.style.display !== "none") {
      closeDrawer();
    }
  });
</script>

<style>
  /* Skip link — hidden off-screen until focused */
  .skip-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 200;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    background-color: var(--color-cta);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    transform: translateY(-200%);
    transition: transform 0.2s;
  }
  .skip-link:focus-visible {
    transform: translateY(0);
  }

  /* Drawer entrance/exit animation */
  #nav-drawer {
    transition: transform 300ms cubic-bezier(0.05, 0.7, 0.1, 1);
  }

  /* Scrim fade */
  #nav-scrim {
    transition: opacity 200ms cubic-bezier(0.2, 0, 0, 1);
  }
</style>
