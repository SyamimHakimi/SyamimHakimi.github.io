---
/**
 * Reusable navigation card used on the home page bento grid.
 *
 * @property href Destination route.
 * @property title Visible card heading.
 * @property description Supporting copy under the heading.
 * @property ctaText Short CTA label shown in the footer row.
 * @property ariaLabel Accessible label for the link target.
 * @property icon SVG path markup rendered inside the icon disc.
 * @property variant Card visual treatment from the design system.
 * @property chips Optional keyword pills rendered above the CTA row.
 */
interface Props {
  href: string;
  title: string;
  description: string;
  ctaText: string;
  ariaLabel: string;
  icon: string;
  variant: "card-elevated" | "card-outlined" | "card-filled";
  chips?: string[];
}

const {
  href,
  title,
  description,
  ctaText,
  ariaLabel,
  icon,
  variant,
  chips = [],
} = Astro.props;

const hasBodySlot = Astro.slots.has("default");
---

<a
  href={href}
  class={`${variant} group flex flex-col no-underline transition-transform hover:-translate-y-0.5`}
  aria-label={ariaLabel}
>
  <div class="icon-disc mb-4" aria-hidden="true">
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      set:html={icon}
    >
    </svg>
  </div>

  <h2 class="mb-2 font-serif text-[22px] font-normal leading-tight text-[var(--color-on-surface)]">
    {title}
  </h2>
  <p class="flex-1 text-[13px] leading-relaxed text-[var(--color-on-surface-variant)]">
    {description}
  </p>

  {hasBodySlot && <div class="mt-5"><slot /></div>}

  {chips.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-1.5">
      {chips.map((chip) => <span class="chip">{chip}</span>)}
    </div>
  )}

  <span class="mt-5 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[var(--color-cta)]">
    {ctaText}
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </span>
</a>
