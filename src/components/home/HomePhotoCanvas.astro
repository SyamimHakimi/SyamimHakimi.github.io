---
/**
 * Dark photography canvas for the home page editorial hero.
 *
 * Wraps LandingPhotos in a dark panel with a gradient overlay and casual copy.
 * data-theme="dark" forces dark-mode CSS tokens on the photo grid so card
 * borders and skeleton states match the dark background. bg-[var(--color-background)]
 * resolves to #1c1917 under forced dark tokens — correct in both page themes.
 */
import LandingPhotos from "../islands/LandingPhotos.vue";

const stats = [
  { value: "340+", label: "Photos", ariaLabel: "340 plus photos" },
  { value: "12",   label: "Albums", ariaLabel: "12 albums" },
  { value: "X-T5", label: "Camera", ariaLabel: "Fujifilm X-T5" },
];
---

<div
  data-theme="dark"
  class="relative flex min-h-[360px] flex-col overflow-hidden rounded-[var(--radius-xl)] bg-[var(--color-background)] sm:min-h-[420px] lg:min-h-0"
>
  <div class="relative min-h-0 flex-1 p-2">
    <LandingPhotos client:visible />
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-[var(--color-background)] to-transparent"
      aria-hidden="true"
    ></div>
  </div>

  <div class="relative z-10 -mt-4 px-5 pb-6 sm:px-8 sm:pb-8">
    <p class="eyebrow-accent mb-2">Photography</p>
    <h2
      class="mb-1.5 font-serif text-[clamp(22px,3.5vw,30px)] font-normal leading-tight text-white"
    >
      Me and my Fujifilm.
    </h2>
    <p class="mb-5 max-w-[38ch] text-[12px] leading-relaxed text-white/60">
      I shoot with an X-T5 when the light looks interesting — film
      simulations, mostly just for fun.
    </p>

    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="flex gap-5" aria-label="Photography stats">
        {stats.map(({ value, label, ariaLabel }) => (
          <div>
            <span
              class="block font-serif text-[22px] leading-none text-white"
              aria-label={ariaLabel}
            >{value}</span>
            <span class="mt-1 block text-[10px] uppercase tracking-[0.08em] text-white/50">
              {label}
            </span>
          </div>
        ))}
      </div>

      <a
        href="/photography"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-[12px] font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        Browse gallery
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</div>
