---
/**
 * Compact freelance availability panel for the home page identity stack.
 * Sits below HomeHero in the right column of the editorial hero layout.
 * data-theme="dark" keeps the panel always dark regardless of page theme.
 */
const tags = ["Web Dev", "Full-stack", "API Design", "Mentoring"];
---

<div
  data-theme="dark"
  class="rounded-[var(--radius-lg)] bg-[var(--color-background)] px-5 py-5 sm:px-7"
>
  <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.08em] text-[var(--color-cta)]">
    Freelance &amp; Consulting
  </p>
  <h3 class="mb-1 font-serif text-[18px] font-normal leading-snug text-[var(--color-on-surface)]">
    Let's build something together.
  </h3>
  <p class="mb-4 text-[12px] leading-relaxed text-[var(--color-on-surface-variant)]">
    Available for engagements from a single sprint to a long-term partnership.
  </p>

  <div class="mb-4 flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="rounded-full border border-white/12 bg-white/8 px-2.5 py-0.5 text-[11px] font-medium text-white/75">
        {tag}
      </span>
    ))}
  </div>

  <a href="/contact" class="button-primary">
    Start a Project
  </a>
</div>
