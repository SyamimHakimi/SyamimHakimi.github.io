---
/**
 * Freelance availability strip — bottom of the home page.
 * Replaces the tech-stack note with a conversion-oriented CTA.
 */
---

<div class="panel-inset flex flex-wrap items-center justify-between gap-x-6 gap-y-3 px-5 py-4">
  <div class="flex items-center gap-3">
    <span class="status-dot" aria-hidden="true"></span>
    <div>
      <p class="text-[13px] font-semibold text-[var(--color-on-surface)]">
        Available for freelance projects
      </p>
      <p class="text-[12px] text-[var(--color-on-surface-variant)]">
        Web development, API design, and code review — direct engagement, no agency overhead.
      </p>
    </div>
  </div>
  <a href="/contact" class="button-primary shrink-0 gap-2 py-2.5 text-[13px]">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    Start a conversation
  </a>
</div>
