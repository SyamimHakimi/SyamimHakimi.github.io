---
/** SiteFooter — minimal footer with copyright. Static HTML, no client JS. */
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-outline)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6">
    <p class="text-center text-sm text-[var(--color-on-surface-variant)]">
      &copy; {year} Syamim Hakimi. All rights reserved.
    </p>
  </div>
</footer>
