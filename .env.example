# Telegram UI Preview Bot
# Used by: node --env-file=.env scripts/ui-preview.mjs
# Get token from @BotFather on Telegram → /newbot
TELEGRAM_TOKEN=your-bot-token-here
# Your personal Telegram user/chat ID (bot must have received at least one message from you)
TELEGRAM_CHAT_ID=your-chat-id-here

# GitHub App — portfolio-agents (used by Claude Code MCP server)
# App ID from: github.com → Settings → Developer settings → GitHub Apps → portfolio-agents
GITHUB_APP_ID=your-app-id-here
# Absolute path to the downloaded .pem private key file (never commit the file itself)
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/scripts/portfolio-agents.private-key.pem

# Firebase service account — used by Phase A1 Firestore export script only
# Point to a downloaded service account JSON key file (never commit the file itself)
# https://console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
